<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Backgrounds -->
    <Color x:Key="NG.Color.BG.Base">#FF0A0B0F</Color>
    <Color x:Key="NG.Color.BG.Surface">#FF12141A</Color>
    <Color x:Key="NG.Color.BG.Elevated">#FF1A1D26</Color>
    <Color x:Key="NG.Color.BG.Overlay">#CC0A0B0F</Color>

    <!-- Accents -->
    <Color x:Key="NG.Color.Cyan">#FF00E5FF</Color>
    <Color x:Key="NG.Color.CyanDim">#3300E5FF</Color>
    <Color x:Key="NG.Color.CyanSubtle">#1A00E5FF</Color>
    <Color x:Key="NG.Color.Blue">#FF0066FF</Color>
    <Color x:Key="NG.Color.BlueDim">#330066FF</Color>

    <!-- Verdict / semantic -->
    <Color x:Key="NG.Color.Allow">#FF00FF88</Color>
    <Color x:Key="NG.Color.AllowDim">#2200FF88</Color>
    <Color x:Key="NG.Color.CapAllow">#FF00E5FF</Color>
    <Color x:Key="NG.Color.CapAllowDim">#2200E5FF</Color>
    <Color x:Key="NG.Color.Block">#FFFF3366</Color>
    <Color x:Key="NG.Color.BlockDim">#22FF3366</Color>
    <Color x:Key="NG.Color.Monitor">#FFFFAA00</Color>
    <Color x:Key="NG.Color.MonitorDim">#22FFAA00</Color>
    <Color x:Key="NG.Color.Permitted">#FF00FF88</Color>
    <Color x:Key="NG.Color.PermittedDim">#2200FF88</Color>

    <!-- Text -->
    <Color x:Key="NG.Color.Text.Primary">#FFE8ECF4</Color>
    <Color x:Key="NG.Color.Text.Secondary">#99E8ECF4</Color>
    <Color x:Key="NG.Color.Text.Muted">#55E8ECF4</Color>
    <Color x:Key="NG.Color.Text.Accent">#FF00E5FF</Color>

    <!-- Borders -->
    <Color x:Key="NG.Color.Border.Subtle">#26FFFFFF</Color>
    <Color x:Key="NG.Color.Border.Accent">#4D00E5FF</Color>
    <Color x:Key="NG.Color.Border.Focus">#FF00E5FF</Color>

    <!-- Panic red -->
    <Color x:Key="NG.Color.Panic">#FFFF3366</Color>
    <Color x:Key="NG.Color.PanicDim">#33FF3366</Color>

    <!-- SolidColorBrushes -->
    <SolidColorBrush x:Key="NG.Brush.BG.Base"        Color="{StaticResource NG.Color.BG.Base}"/>
    <SolidColorBrush x:Key="NG.Brush.BG.Surface"     Color="{StaticResource NG.Color.BG.Surface}"/>
    <SolidColorBrush x:Key="NG.Brush.BG.Elevated"    Color="{StaticResource NG.Color.BG.Elevated}"/>
    <SolidColorBrush x:Key="NG.Brush.Cyan"           Color="{StaticResource NG.Color.Cyan}"/>
    <SolidColorBrush x:Key="NG.Brush.CyanDim"        Color="{StaticResource NG.Color.CyanDim}"/>
    <SolidColorBrush x:Key="NG.Brush.CyanSubtle"     Color="{StaticResource NG.Color.CyanSubtle}"/>
    <SolidColorBrush x:Key="NG.Brush.Blue"           Color="{StaticResource NG.Color.Blue}"/>
    <SolidColorBrush x:Key="NG.Brush.Text.Primary"   Color="{StaticResource NG.Color.Text.Primary}"/>
    <SolidColorBrush x:Key="NG.Brush.Text.Secondary" Color="{StaticResource NG.Color.Text.Secondary}"/>
    <SolidColorBrush x:Key="NG.Brush.Text.Muted"     Color="{StaticResource NG.Color.Text.Muted}"/>
    <SolidColorBrush x:Key="NG.Brush.Text.Accent"    Color="{StaticResource NG.Color.Text.Accent}"/>
    <SolidColorBrush x:Key="NG.Brush.Border.Subtle"  Color="{StaticResource NG.Color.Border.Subtle}"/>
    <SolidColorBrush x:Key="NG.Brush.Border.Accent"  Color="{StaticResource NG.Color.Border.Accent}"/>
    <SolidColorBrush x:Key="NG.Brush.Panic"          Color="{StaticResource NG.Color.Panic}"/>
    <SolidColorBrush x:Key="NG.Brush.PanicDim"       Color="{StaticResource NG.Color.PanicDim}"/>

    <!-- Verdict foreground brushes (looked up by SemBrush converter) -->
    <SolidColorBrush x:Key="NG.Brush.Verdict.Allow"     Color="{StaticResource NG.Color.Allow}"/>
    <SolidColorBrush x:Key="NG.Brush.Verdict.CapAllow"  Color="{StaticResource NG.Color.CapAllow}"/>
    <SolidColorBrush x:Key="NG.Brush.Verdict.Block"     Color="{StaticResource NG.Color.Block}"/>
    <SolidColorBrush x:Key="NG.Brush.Verdict.Monitor"   Color="{StaticResource NG.Color.Monitor}"/>
    <SolidColorBrush x:Key="NG.Brush.Verdict.Permitted" Color="{StaticResource NG.Color.Permitted}"/>

    <!-- Verdict background brushes -->
    <SolidColorBrush x:Key="NG.Brush.Verdict.Allow.BG"     Color="{StaticResource NG.Color.AllowDim}"/>
    <SolidColorBrush x:Key="NG.Brush.Verdict.CapAllow.BG"  Color="{StaticResource NG.Color.CapAllowDim}"/>
    <SolidColorBrush x:Key="NG.Brush.Verdict.Block.BG"     Color="{StaticResource NG.Color.BlockDim}"/>
    <SolidColorBrush x:Key="NG.Brush.Verdict.Monitor.BG"   Color="{StaticResource NG.Color.MonitorDim}"/>
    <SolidColorBrush x:Key="NG.Brush.Verdict.Permitted.BG" Color="{StaticResource NG.Color.PermittedDim}"/>

    <!-- Acrylic brushes -->
    <AcrylicBrush x:Key="NG.Brush.Acrylic.Sidebar"
        TintColor="{StaticResource NG.Color.BG.Surface}"
        TintOpacity="0.90"
        FallbackColor="{StaticResource NG.Color.BG.Surface}"/>

    <AcrylicBrush x:Key="NG.Brush.Acrylic.TabBar"
        TintColor="{StaticResource NG.Color.BG.Surface}"
        TintOpacity="0.85"
        FallbackColor="{StaticResource NG.Color.BG.Surface}"/>

    <!-- Shape tokens -->
    <CornerRadius x:Key="NG.Corner.Card">8</CornerRadius>
    <CornerRadius x:Key="NG.Corner.Badge">4</CornerRadius>
    <CornerRadius x:Key="NG.Corner.Button">6</CornerRadius>
    <CornerRadius x:Key="NG.Corner.Input">6</CornerRadius>

    <Thickness x:Key="NG.Border.Thin">1</Thickness>
    <Thickness x:Key="NG.Padding.Card">16,12,16,12</Thickness>
    <Thickness x:Key="NG.Padding.Badge">8,3,8,3</Thickness>
    <Thickness x:Key="NG.Padding.Row">12,8,12,8</Thickness>
    <Thickness x:Key="NG.Padding.SidebarItem">16,10,16,10</Thickness>

</ResourceDictionary>
