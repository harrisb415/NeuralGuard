<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="NeuralGuard.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:NeuralGuard"
    RequestedTheme="Dark">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <ResourceDictionary Source="ms-appx:///Themes/NeuralGuardColors.xaml" />
                <ResourceDictionary Source="ms-appx:///Themes/NeuralGuardStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Neon cyan accent (replaces the default system accent) -->
            <Color x:Key="SystemAccentColor">#FF00E5FF</Color>
            <Color x:Key="SystemAccentColorDark1">#FF00BBCC</Color>
            <Color x:Key="SystemAccentColorDark2">#FF008899</Color>
            <Color x:Key="SystemAccentColorLight1">#FF33EEFF</Color>

            <!-- Sidebar + list selection = neon cyan -->
            <SolidColorBrush x:Key="NavigationViewSelectionIndicatorForeground" Color="{StaticResource NG.Color.Cyan}" />
            <SolidColorBrush x:Key="NavigationViewItemForegroundSelected" Color="{StaticResource NG.Color.Text.Primary}" />
            <SolidColorBrush x:Key="NavigationViewItemBackgroundSelected" Color="{StaticResource NG.Color.CyanSubtle}" />
            <SolidColorBrush x:Key="NavigationViewItemBackgroundSelectedPointerOver" Color="{StaticResource NG.Color.CyanDim}" />
            <SolidColorBrush x:Key="ListViewItemBackgroundSelected" Color="{StaticResource NG.Color.CyanSubtle}" />
            <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPointerOver" Color="{StaticResource NG.Color.CyanDim}" />
            <SolidColorBrush x:Key="ListViewItemBackgroundPointerOver" Color="{StaticResource NG.Color.CyanSubtle}" />

            <!-- Semantic cell-color converter (Live verdicts, Baseline state, ...) -->
            <local:SemBrush x:Key="SemBrush" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
