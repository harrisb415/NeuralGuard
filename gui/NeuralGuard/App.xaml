<?xml version="1.0" encoding="utf-8"?>
<!-- No RequestedTheme here: an Application-level theme is fixed for the process
     lifetime and can never change again. The theme is applied per-window instead,
     on the root FrameworkElement (MainWindow::ApplyTheme), driven by
     meta('theme') - 'dark' (default, the designed look) | 'light' | 'system'.
     ElementTheme::Default on the root = follow Windows, which is what makes the
     'system' option live-track the OS setting. -->
<Application
    x:Class="NeuralGuard.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:NeuralGuard">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <ResourceDictionary Source="ms-appx:///Themes/NeuralGuardColors.xaml" />
                <ResourceDictionary Source="ms-appx:///Themes/NeuralGuardStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- The accent + sidebar/list-selection system-key overrides used to
                 live here, bound with {StaticResource NG.Color.*}. They moved into
                 the ThemeDictionaries in NeuralGuardColors.xaml: an app-level
                 resource is resolved once at parse time, so anything defined here
                 could never follow a runtime theme switch. -->

            <!-- Semantic cell-color converter (Live verdicts, Baseline state, ...) -->
            <local:SemBrush x:Key="SemBrush" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
